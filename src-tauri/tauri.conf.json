{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Handless",
  "version": "0.2.9",
  "identifier": "com.handless.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "resources": ["resources/**/*"],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {}
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzMTU5NTkxOTEwOTI2RDEKUldUUkpnbVJrWlVWUTBEN0NBbFFoZlZ0WW5NZXZuS2pqRzdvUS9FUXMwT2kxQUVsUG8ycExpNWMK",
      "endpoints": [
        "https://github.com/ElwinLiu/handless/releases/latest/download/latest.json"
      ]
    }
  }
}
